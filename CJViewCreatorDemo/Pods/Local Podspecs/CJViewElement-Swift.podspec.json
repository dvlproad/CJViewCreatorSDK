{
  "name": "CJViewElement-Swift",
  "version": "0.0.1",
  "summary": "视图绘制库（类似无边记，常用于组件APP里的组件详情页）",
  "homepage": "https://github.com/dvlproad/CJViewCreatorSDK.git",
  "license": "MIT",
  "authors": "dvlproad",
  "description": "视图绘制库（类似无边记，常用于组件APP里的组件详情页），可按需独立引入：\n• CJViewElement-Swift/LayoutInputView - 布局调整的设置视图\n• CJViewElement-Swift/Extension - 需要用到的基础的扩展（Color等)\n• CJViewElement-Swift/Model - 底层视图数据模型\n• CJViewElement-Swift/ComponentConfigModel - 组件视图配置模型\n• CJViewElement-Swift/CommonSettingRow - 视图设置图（类似组件APP里的组件详情页的底部设置图）\n• CJViewElement-Swift/SquareResultView - 预览图（类似组件APP里的组件详情页的顶部预览图）\n\n每个子库可独立引入，详见各子库描述。",
  "platforms": {
    "ios": "17.0"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://github.com/dvlproad/CJViewCreatorSDK.git",
    "tag": "CJViewElement-Swift_0.1.0"
  },
  "frameworks": "UIKit",
  "requires_arc": true,
  "subspecs": [
    {
      "name": "LayoutInputView",
      "source_files": "CJViewElement-Swift/LayoutInputView/**/*.{swift}"
    },
    {
      "name": "Extension",
      "source_files": "CJViewElement-Swift/Extension/**/*.{swift}"
    },
    {
      "name": "Model",
      "source_files": "CJViewElement-Swift/ElementModel/**/*.{swift}",
      "dependencies": {
        "CJViewElement-Swift/Extension": []
      }
    },
    {
      "name": "ComponentConfigModel",
      "source_files": "CJViewElement-Swift/ComponentConfigModel/**/*.{swift}",
      "dependencies": {
        "CJViewElement-Swift/Model": []
      }
    },
    {
      "name": "CommonSettingRow",
      "source_files": "CJViewElement-Swift/CommonSettingRow/**/*.{swift}",
      "dependencies": {
        "CJViewElement-Swift/ComponentConfigModel": [],
        "CJViewElement-Swift/LayoutInputView": []
      }
    },
    {
      "name": "SquareResultView",
      "source_files": "CJViewElement-Swift/SquareResultView/**/*.{swift}",
      "dependencies": {
        "CJViewElement-Swift/ComponentConfigModel": []
      }
    }
  ],
  "swift_version": "5.0"
}
