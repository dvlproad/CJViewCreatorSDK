{
  "name": "CQViewElement-Swift",
  "version": "0.0.1",
  "summary": "视图绘制库（类似无边记，常用于组件APP里的组件详情页）",
  "homepage": "https://github.com/dvlproad/CJViewCreatorSDK.git",
  "license": "MIT",
  "authors": "dvlproad",
  "description": "视图绘制库（类似无边记，常用于组件APP里的组件详情页），可按需独立引入：\n• CQViewElement-Swift/LayoutInputView - 布局调整的设置视图\n• CQViewElement-Swift/Extension - 需要用到的基础的扩展（Color等)\n• CQViewElement-Swift/Model - 底层视图数据模型\n• CQViewElement-Swift/ComponentConfigModel - 组件视图配置模型\n• CQViewElement-Swift/CommonSettingRow - 视图设置图（类似组件APP里的组件详情页的底部设置图）\n• CQViewElement-Swift/SquareResultView - 预览图（类似组件APP里的组件详情页的顶部预览图）\n\n每个子库可独立引入，详见各子库描述。",
  "platforms": {
    "ios": "17.0"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://github.com/dvlproad/CJViewCreatorSDK.git",
    "tag": "CQViewElement-Swift_0.1.0"
  },
  "frameworks": "UIKit",
  "requires_arc": true,
  "resource_bundles": {
    "CQViewElement-Swift": [
      "CQViewElement-Swift/Resources/**/*.{ttf,webp}"
    ]
  },
  "subspecs": [
    {
      "name": "ComponentConfigModel",
      "source_files": "CQViewElement-Swift/ComponentConfigModel/**/*.{swift}",
      "dependencies": {
        "CJViewElement-Swift/ComponentConfigModel": [],
        "CJDataVientianeSDK-Swift/Date": []
      }
    },
    {
      "name": "SettingRow",
      "source_files": "CQViewElement-Swift/SettingRow/**/*.{swift}",
      "dependencies": {
        "CQViewElement-Swift/ComponentConfigModel": [],
        "CQDemoKit/BaseUtil": []
      }
    },
    {
      "name": "SquareResultView",
      "source_files": "CQViewElement-Swift/SquareResultView/**/*.{swift}",
      "dependencies": {
        "CQViewElement-Swift/ComponentConfigModel": [],
        "CJViewGR-Swift": []
      }
    }
  ],
  "swift_version": "5.0"
}
